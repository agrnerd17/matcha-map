generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  reviews   Review[]
  cafes     Cafe[]   @relation("CreatedCafes")
  createdAt DateTime @default(now())
}

model Cafe {
  id          Int      @id @default(autoincrement())
  name        String
  address     String
  city        String
  state       String
  description String?
  createdById Int
  createdBy   User     @relation("CreatedCafes", fields: [createdById], references: [id])
  reviews     Review[]
  createdAt   DateTime @default(now())
}

model Review {
  id               Int      @id @default(autoincrement())
  userId           Int
  cafeId           Int
  drinkName        String
  tasteRating      Int
  sweetnessRating  Int
  qualityRating    Int
  priceRating      Int
  atmosphereRating Int
  overallRating    Int
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  cafe Cafe @relation(fields: [cafeId], references: [id])
}